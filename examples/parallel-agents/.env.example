# Optional local orchestration configuration.
# This deterministic simulator makes no model or provider API calls and needs
# no API keys. Export these values before running merge-parallel-work.sh.
AGENT_BRANCH_PREFIX=agent/
MAIN_BRANCH=main
REPORTS_DIR=./reports
SHARED_MEMORY=./shared-memory/agent_memory.json

# Docker Compose project name
COMPOSE_PROJECT_NAME=parallel-agents
