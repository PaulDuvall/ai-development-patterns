{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "./stop-hook.sh"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git rev-parse:*)",
      "Bash(./done-check.sh)",
      "Read",
      "Edit"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Read(./.env)",
      "Read(./secrets/**)"
    ]
  }
}
